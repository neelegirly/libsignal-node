{
  "name": "@neelify/libsignal",
  "version": "1.0.26",
  "description": "Signal protocol crypto dependency for @neelify/baileys on Node.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/neelify/libsignal-node.git"
  },
  "homepage": "https://github.com/neelify/libsignal-node#readme",
  "bugs": {
    "url": "https://github.com/neelify/libsignal-node/issues"
  },
  "main": "index.js",
  "keywords": [
