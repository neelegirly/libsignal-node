{
  "name": "@neelegirly/libsignal",
  "version": "1.0.32",
  "description": "Signal protocol crypto dependency for @neelegirly/baileys on Node.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/neelegirly/libsignal-node.git"
  },
  "homepage": "https://github.com/neelegirly/libsignal-node#readme",
  "bugs": {
    "url": "https://github.com/neelegirly/libsignal-node/issues"
  },
  "main": "index.js",
  "keywords": [
    "signal",
    "whispersystems",
    "crypto",
    "signal-protocol",
    "neelegirly",
    "baileys"
  ],
  "license": "MIT",
  "scripts": {
    "build": "pbjs -t static-module -w commonjs -o ./src/WhisperTextProtocol.js ./protos/WhisperTextProtocol.proto",
    "test": "node --check index.js && node --check src/curve.js && node --check src/session_builder.js && node --check src/session_cipher.js && node -e \"const s=require('./'); if(typeof s.ProtocolAddress !== 'function' || typeof s.curve.getPublicFromPrivateKey !== 'function') process.exit(1)\""
  },
  "dependencies": {
    "curve25519-js": "^0.0.4",
    "protobufjs": "7.5.0"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "protos/**/*",
    "src/**/*",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "eslint": "6.0.1",
    "protobufjs-cli": "1.1.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "types": "index.d.ts"
}
